# =============================================================================
# Supabase
# =============================================================================
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# =============================================================================
# Pangle App ID（OSごとに1つ）
# Pangle管理画面 > アプリ > App ID をコピー
# =============================================================================
VITE_PANGLE_ANDROID_APP_ID=
VITE_PANGLE_IOS_APP_ID=

# Safari Web Inspector で広告ログを詳しく見る（任意）
# VITE_AD_DEBUG_LOG=1

# =============================================================================
# バナー広告 Placement ID
# Pangle管理画面の広告枠名 → 下記 env キーへ登録
# =============================================================================

# ホーム画面バナー（320×50）— 実表示テストはここだけ設定すればOK
# Pangle管理画面 > 広告枠 > 「ホーム画面バナー」> Placement ID（コード）
# アプリ: index.html .app-banner-under-footer / adConfig: banner_home
VITE_PANGLE_ANDROID_BANNER_HOME=
VITE_PANGLE_IOS_BANNER_HOME=

# アカウント画面バナー（300×250）
# アプリ: .ad-banner-account-inline
# adConfig: banner_account
VITE_PANGLE_ANDROID_BANNER_ACCOUNT=
VITE_PANGLE_IOS_BANNER_ACCOUNT=

# 獲得モーダルバナー（300×250）
# アプリ: .reward-sheet-banner
# adConfig: banner_reward_modal
VITE_PANGLE_ANDROID_BANNER_REWARD_MODAL=
VITE_PANGLE_IOS_BANNER_REWARD_MODAL=

# ポイントルーレットバナー（300×250）
# アプリ: 豚ガラポン画面 .garapon-ad-banner-slot
# adConfig: banner_roulette
VITE_PANGLE_ANDROID_BANNER_ROULETTE=
VITE_PANGLE_IOS_BANNER_ROULETTE=

# ゲーム画面バナー（300×250）
# アプリ: .game-ad-banner-slot
# adConfig: banner_game
VITE_PANGLE_ANDROID_BANNER_GAME=
VITE_PANGLE_IOS_BANNER_GAME=

# =============================================================================
# リワード動画 Placement ID
# =============================================================================

# cmを見てリワード
# アプリ: ホーム「動画を見て80＋豚チケット」→ showRewardedAdFor80Points（将来接続）
# adConfig: rewarded_80pt
VITE_PANGLE_ANDROID_REWARDED_80PT=
VITE_PANGLE_IOS_REWARDED_80PT=

# ブーストリワード
# アプリ: ホームブースト確認後 → showRewardedAdForBoost（将来接続）
# adConfig: rewarded_boost
VITE_PANGLE_ANDROID_REWARDED_BOOST=
VITE_PANGLE_IOS_REWARDED_BOOST=

# 砂時計リワード
# アプリ: 砂時計消費系リワード用（Pangle枠確保済み・現状UI未接続）
# adConfig: rewarded_hourglass
VITE_PANGLE_ANDROID_REWARDED_HOURGLASS=
VITE_PANGLE_IOS_REWARDED_HOURGLASS=

# =============================================================================
# インタースティシャル Placement ID
# =============================================================================

# 再起動インステ
# アプリ: showInterstitialOnAppLaunch（将来接続）
# adConfig: interstitial_app_resume
VITE_PANGLE_ANDROID_INTERSTITIAL_APP_RESUME=
VITE_PANGLE_IOS_INTERSTITIAL_APP_RESUME=

# ワークエンドインステ
# アプリ: 作業終了後ホーム戻り → showInterstitialAfterWorkEnd（将来接続）
# adConfig: interstitial_work_end
VITE_PANGLE_ANDROID_INTERSTITIAL_WORK_END=
VITE_PANGLE_IOS_INTERSTITIAL_WORK_END=

# ルーレット3回インステ
# アプリ: ガラポン3回転ごと → showInterstitialAfterRouletteEvery3Spins（将来接続）
# adConfig: interstitial_roulette_3spins
VITE_PANGLE_ANDROID_INTERSTITIAL_ROULETTE_3SPINS=
VITE_PANGLE_IOS_INTERSTITIAL_ROULETTE_3SPINS=
